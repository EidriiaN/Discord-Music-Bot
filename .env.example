# Discord Music Bot - Environment Configuration
# Copy this file to .env and fill in your values
# For Portainer: Add these as environment variables in the stack configuration

# =============================================================================
# REQUIRED - Bot will not start without these
# =============================================================================

# Discord Bot Token (from Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your_bot_token_here

# Discord Application/Client ID (from Discord Developer Portal -> General Information)
CLIENT_ID=your_client_id_here

# =============================================================================
# YOUTUBE AUTHENTICATION (2026 Bypass)
# Required for YouTube playback - see development.md for extraction guide
# =============================================================================

# Proof-of-Origin Token (extract from browser Network tab -> player request -> Payload)
PO_TOKEN=your_po_token_here

# Visitor Data (extract from same location as PO_TOKEN)
VISITOR_DATA=your_visitor_data_here

# =============================================================================
# OPTIONAL - Alternative cookie authentication
# =============================================================================

# Base64-encoded YouTube cookies (alternative to cookies.txt file mount)
# To encode: base64 -w 0 cookies.txt (Linux) or [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt")) (PowerShell)
# Useful for Portainer where file mounts may be inconvenient
YOUTUBE_COOKIES=

# =============================================================================
# PORTAINER DEPLOYMENT NOTES
# =============================================================================
# 1. In Portainer, go to Stacks -> Add Stack
# 2. Upload or paste the docker-compose.yml content
# 3. Add environment variables in the "Environment variables" section
# 4. For YOUTUBE_COOKIES, use Base64-encoded value (no newlines)
# 5. Deploy the stack
#
# To encode cookies.txt for Portainer (PowerShell):
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt")) | Set-Clipboard
#
# To encode cookies.txt for Portainer (Linux/Mac):
#   base64 -w 0 cookies.txt | xclip -selection clipboard
